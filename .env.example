################################################################################
# GitHub Actions Environment Variables Template
# 
# Copy this file to .env.local or set these as GitHub Actions secrets
# 
# How to set GitHub Actions secrets:
# 1. Go to Settings → Secrets and variables → Actions
# 2. Click "New repository secret"
# 3. Add each variable as shown below
################################################################################

# ============================================================================
# SLACK WEBHOOK - For error notifications and status updates
# ============================================================================
# Get this from: Slack Workspace → Settings → Apps & integrations → Webhooks
# Should look like: https://hooks.slack.com/services/TXXX/BXXX/XXXX
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR_SLACK_WEBHOOK

# ============================================================================
# SERVER DOMAIN - GitHub Runner Controller server address
# ============================================================================
# Examples:
#   - localhost:8001
#   - example.com:8001
#   - 192.168.1.100:8001
#   - axovps.firedns.xyz:8000
SERVER_DOMAIN=axovps.firedns.xyz:8000

# ============================================================================
# BASIC AUTH - Base64 encoded credentials
# ============================================================================
# Default credentials for GitHub Runner Controller:
#   Username: runner
#   Password: subdomian_takeover_tool_automation
#
# To encode: echo -n "username:password" | base64
# 
# Example base64 for default credentials:
#   runner:subdomian_takeover_tool_automation
#   Base64: cnVubmVyOnN1YmRvbWlhbl90YWtlb3Zlcl90b29sX2F1dG9tYXRpb24=
#
# Note: Do NOT commit the actual credentials! Use GitHub Actions secrets instead
BASIC_AUTH=cnVubmVyOnN1YmRvbWlhbl90YWtlb3Zlcl90b29sX2F1dG9tYXRpb24=

# ============================================================================
# DISCORD WEBHOOK (Optional - for test-trigger.yml)
# ============================================================================
# For Discord notifications instead of Slack
DISCORD_WEBHOOK_TEST=https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK

################################################################################
# SECURITY NOTES
# ============================================================================
# 
# 1. NEVER commit sensitive values to the repository
# 2. Use GitHub Actions "Secrets" for all sensitive variables
# 3. To add secrets in GitHub:
#    - Settings → Secrets and variables → Actions
#    - Click "New repository secret"
#    - Name: SLACK_WEBHOOK, Value: your_webhook_url
#    - Name: SERVER_DOMAIN, Value: your_server_domain
#    - Name: BASIC_AUTH, Value: your_base64_credentials
#
# 4. Access in workflows:
#    - ${{ secrets.SLACK_WEBHOOK }}
#    - ${{ secrets.SERVER_DOMAIN }}
#    - ${{ secrets.BASIC_AUTH }}
#
# 5. This file (.env.example) can be committed
#    - It shows what variables are needed
#    - Never contains actual secret values
#
################################################################################

# ============================================================================
# QUICK SETUP GUIDE
# ============================================================================
#
# Step 1: Create GitHub secrets
# ─────────────────────────────────────
# Go to: Your Repository → Settings → Secrets and variables → Actions
# Click: New repository secret
#
# Add these secrets:
#   Secret Name: SLACK_WEBHOOK
#   Value: <your Slack webhook URL>
#
#   Secret Name: SERVER_DOMAIN  
#   Value: <your server domain>
#
#   Secret Name: BASIC_AUTH
#   Value: <base64 encoded credentials>
#
# Step 2: Create trigger directory (for test-trigger.yml)
# ─────────────────────────────────────
# mkdir trigger/
# echo "test" > trigger/README.md
# git add trigger/
# git commit -m "Add trigger directory for GitHub Actions"
# git push
#
# Step 3: Run workflow
# ─────────────────────────────────────
# The workflow will automatically trigger on push
# Or manually trigger from: Actions tab → Choose workflow → Run workflow
#
# Step 4: Monitor execution
# ─────────────────────────────────────
# - GitHub: Actions tab in your repository
# - Slack: Check configured webhook channel
# - Discord: Check configured webhook channel
#
################################################################################
